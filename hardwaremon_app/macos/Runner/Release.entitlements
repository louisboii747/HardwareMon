<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  HardwareMon launches its bundled telemetry helper. This release build is
	  distributed outside the Mac App Store, so App Sandbox is deliberately
	  disabled; a sandboxed parent cannot launch this standalone PyInstaller
	  helper with the access it needs to collect system telemetry.
	-->
</dict>
</plist>
